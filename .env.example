# =============================================================================
# Advantage PWA — Environment Variables Reference
# =============================================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# =============================================================================

# ----------------------------------------------------------------------------
# Cloudflare Turnstile (bot protection on contact/booking forms)
# https://dash.cloudflare.com → Turnstile
# ----------------------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ----------------------------------------------------------------------------
# Taskboard webhook — lead capture pipeline (ContactForm → advantage-taskboard)
# Format: https://app.advantagenys.com/api/webhooks/pwa-lead
# ----------------------------------------------------------------------------
TASKBOARD_WEBHOOK_URL=

# ----------------------------------------------------------------------------
# Booking API — /book page thin client (Worker A: feat/book-consumer-and-floating-contact)
#
# NEXT_PUBLIC_BOOK_LIVE:
#   Set to "true" to activate live booking against taskboard's API.
#   Default (unset or any other value): inert mode — forms fall back to /api/contact.
#   Flip to "true" after taskboard fix/book-defects-r1 merges to prod and
#   BREVO_API_KEY is confirmed set on app.advantagenys.com Vercel env.
#
# NEXT_PUBLIC_BOOK_API_BASE:
#   Base URL for the taskboard booking API.
#   Default (unset): https://app.advantagenys.com
#   Use https://staging.advantagenys.com for staging validation.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_BOOK_LIVE=false
NEXT_PUBLIC_BOOK_API_BASE=https://app.advantagenys.com

# ----------------------------------------------------------------------------
# AOS (Advantage Operating System) booking — Phase 1 path (separate from /book)
# Only needed if NEXT_PUBLIC_AOS_BOOKING_MODE is set to "redirect" or "iframe".
# ----------------------------------------------------------------------------
NEXT_PUBLIC_AOS_BOOKING_MODE=form
NEXT_PUBLIC_AOS_BOOKING_BASE_URL=

# ----------------------------------------------------------------------------
# Web Push / VAPID (PWA push notifications — Phase 2 + 3)
# Generate keys: npx web-push generate-vapid-keys
# Public key: set in Vercel env as NEXT_PUBLIC_VAPID_PUBLIC_KEY (all envs)
# Private key: set in Vercel env as VAPID_PRIVATE_KEY (server-side only, never expose)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ----------------------------------------------------------------------------
# Analytics (all optional — loaded via GTM when set)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_CLARITY_ID=
